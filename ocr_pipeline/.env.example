# ── OCR Document Pipeline · Environment Variables ──────────────────────────────

# OpenAI — required for LLM classification
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenAI model to use (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Redis connection URL
# Set to "memory://" to use the in-process dict store (no Redis needed for local dev)
REDIS_URL=memory://
# REDIS_URL=redis://localhost:6379/0

# Result TTL in seconds (default: 86400 = 24 h)
RESULT_TTL_SECONDS=86400

# Maximum upload file size in megabytes (default: 20)
MAX_FILE_SIZE_MB=20

# Default OCR language (Tesseract lang code, default: eng)
OCR_LANG=eng

# Set to "true" to use a stub LLM that never calls OpenAI (useful for CI without API key)
MOCK_LLM=false
